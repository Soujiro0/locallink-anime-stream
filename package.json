  "pkg": {
    "assets": [
      "client/dist/**/*",
      "src/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "resedit": "^3.0.2",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
