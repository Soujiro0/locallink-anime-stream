{
  "name": "locallink",
  "version": "1.2.4",
  "description": "",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "test": "vitest run",
    "start": "node --optimize-for-size index.js",
    "build:client": "cd client && npm install && npm run build",
    "package": "pkg . --targets node18-linux-x64,node18-win-x64 --out-path dist-bin",
    "postpackage": "node set-icon.js",
    "release": "standard-version",
    "postinstall": "node -e \"try{const fs=require('fs'),p=require('path'),d=p.join(p.dirname(require.resolve('cycletls/package.json')),'dist');if(process.platform!=='win32'&&fs.existsSync(d))fs.readdirSync(d).forEach(f=>{if(!f.endsWith('.js')&&!f.endsWith('.ts')&&!f.endsWith('.map')&&!f.endsWith('.json'))try{fs.chmodSync(p.join(d,f),0o755)}catch(e){}})}catch(e){}\""
  },
  "pkg": {
    "assets": [
      "client/dist/**/*",
      "src/**/*",
      "node_modules/cycletls/dist/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cycletls": "^2.0.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "resedit": "^3.0.2",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
