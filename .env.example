# Server Configuration
NODE_ENV=development
PORT=3000

# Application Behavior
# Set to "true" to disable the startup prompt that asks to open the browser (recommended for Docker/headless)
NO_PROMPT=true

# Set to "true" to disable stream token generation and HMAC validation (useful for local private Docker networks)
PRIVATE_MODE=false

# Authoritative Security Architecture (CLOUDFLARE_TOKEN_WHITELIST.md)
# Secret key used for cryptographic HMAC stream token signing & IP-binding
STREAM_WHITELIST_SECRET=locallink-secure-hmac-key-2026

# Upstream API Endpoint Configuration
MIRURO_PIPE_URL="https://www.miruro.tv/api/secure/pipe"

# Cloudflare First-Party Clearance (Optional fallback if direct browser clearance cookie is needed)
CF_CLEARANCE_MIRURO="cf_clearance=YOUR_COPIED_COOKIE_VALUE_HERE"
CF_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36 Edg/136.0.0.0"

# Optional WAF Controlled-Zone Bypass Header
CF_BYPASS_SECRET=""